"""
Config for ListeningAI demo server and as a reference for host projects.

Copy to config.py (gitignored) and fill in credentials. Prefer environment
variables for secrets when possible.
"""
import os

# --- OpenRouter (LLM) ---
OPENROUTER_API_URL = "https://openrouter.ai/api/v1/chat/completions"
OPENROUTER_API_KEY = os.environ.get("OPENROUTER_API_KEY", "")

OPENROUTER_MODEL = "openai/gpt-oss-20b:free"
OPENROUTER_TOOLS_MODEL = "openai/gpt-oss-20b:free"
OPENROUTER_FALLBACK_MODELS = [
    "openai/gpt-oss-120b:free",
    "meta-llama/llama-3.3-70b-instruct:free",
    "meta-llama/llama-3.2-3b-instruct:free",
]
OPENROUTER_TOOLS_FALLBACK_MODELS = [
    "openai/gpt-oss-120b:free",
    "meta-llama/llama-3.3-70b-instruct:free",
]

LLM_TEMPERATURE = 0.7
LLM_MAX_TOKENS = 800

OPENROUTER_SITE_URL = "https://github.com/mickeyshaughnessy/ListeningAI"
OPENROUTER_SITE_NAME = "ListeningAI"

# --- Flask ---
SECRET_KEY = os.environ.get("LISTENING_AI_SECRET_KEY", "dev-secret-change-me")
FLASK_HOST = "0.0.0.0"
FLASK_PORT = 5099
DEBUG = True

# --- Storage ---
# "json"  -> local data/db.json (default for demos)
# "spaces" -> DigitalOcean Spaces / S3-compatible object store
STORE_BACKEND = os.environ.get("LISTENING_AI_STORE", "json")

DATA_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), "data")
DB_PATH = os.path.join(DATA_DIR, "db.json")

# DigitalOcean Spaces (used when STORE_BACKEND=spaces)
DO_SPACES_KEY = os.environ.get("DO_SPACES_KEY", "")
DO_SPACES_SECRET = os.environ.get("DO_SPACES_SECRET", "")
DO_SPACES_REGION = os.environ.get("DO_SPACES_REGION", "sfo3")
DO_SPACES_ENDPOINT = os.environ.get(
    "DO_SPACES_ENDPOINT", f"https://{DO_SPACES_REGION}.digitaloceanspaces.com"
)
DO_SPACES_BUCKET = os.environ.get("DO_SPACES_BUCKET", "")
# All ListeningAI objects live under this key prefix
S3_PREFIX = os.environ.get("LISTENING_AI_PREFIX", "listening_ai/")

# --- Auth ---
TOKEN_EXPIRY_SECONDS = 86400 * 7  # 7 days
